<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<GridPane alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
          prefHeight="400.0" prefWidth="600.0"
          xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25"
          fx:controller="org.example.tiendaapp.controller.LoginController">
    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
    </rowConstraints>
    <children>
        <TextField fx:id="txtCorreo" promptText="Introduce tu correo" GridPane.columnSpan="2" GridPane.rowIndex="1">
            <GridPane.margin>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
            </GridPane.margin>
        </TextField>
        <TextField fx:id="txtPassword" promptText="Introduce tu password" GridPane.columnSpan="2" GridPane.rowIndex="2">
            <GridPane.margin>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
            </GridPane.margin>
        </TextField>
        <Button fx:id="btnRegistrar" alignment="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                style="-fx-background-color: #0DBD11; -fx-background-radius: 20;" text="Registrar" textFill="WHITE"
                GridPane.halignment="CENTER" GridPane.rowIndex="3">
            <GridPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </GridPane.margin>
            <font>
                <Font name="System Bold" size="14.0"/>
            </font>
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </Button>
        <Button fx:id="btnLogin" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                style="-fx-background-color: #1AA5FF; -fx-background-radius: 20;" text="Login" textFill="WHITE"
                GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="3">
            <GridPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </GridPane.margin>
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
            <font>
                <Font name="System Bold" size="14.0"/>
            </font>
        </Button>
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="TIENDA THE POWER" GridPane.columnSpan="2"
              GridPane.halignment="CENTER"/>
    </children>
</GridPane>
